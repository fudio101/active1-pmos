# Maintainer: fudio101 <thenguyen1024@gmail.com>
# Reference: <https://postmarketos.org/devicepkg>
maintainer="Alexey Minnekhanov <alexeymin@minlexx.ru>"
pkgname=device-vsmart-zangyapro
pkgdesc="Vsmart Active 1"
pkgver=3
pkgrel=3
url="https://postmarketos.org"
license="MIT"
arch="aarch64"
options="!check !archcheck"
# NetworkManager (+WiFi backend), wpa_supplicant and openssh are pulled in by
# the chosen UI (postmarketos-ui-console -> postmarketos-base-ui-networkmanager)
# and postmarketos-base, so they are NOT listed here. Only device-specific bits
# stay: the firmware (board-2.bin for WiFi + a512_zap.mbn for the GPU, both in
# firmware-vsmart-zangyapro; a530 microcode in firmware-qcom-adreno-a530), the
# kernel, the SoC glue, and bluez (base-ui only integrates BT *if* bluez is
# present, so keep it to guarantee the auto-start symlink below works).
depends="
	bluez
	firmware-qcom-adreno-a530
	firmware-vsmart-zangyapro
	linux-postmarketos-qcom-sdm660
	mkbootimg
	msm-firmware-loader
	postmarketos-base
	soc-qcom-sdm660
	soc-qcom-sdm660-rproc

"
makedepends="devicepkg-dev"
source="
	deviceinfo
	modules-initfs
"

build() {
	devicepkg_build $startdir $pkgname
}

package() {
	devicepkg_package $startdir $pkgname

	# Auto-start Bluetooth at boot (for a BT keyboard on a headless box)
	# and make sure WiFi (NetworkManager) and SSH come up too. The firmware
	# (board-2.bin for WiFi, a512_zap.mbn for the GPU) ships in
	# firmware-vsmart-zangyapro, which is a hard dependency above.
	install -dm755 "$pkgdir"/etc/systemd/system/multi-user.target.wants
	ln -sf /usr/lib/systemd/system/bluetooth.service \
		"$pkgdir"/etc/systemd/system/multi-user.target.wants/bluetooth.service
}

sha512sums="
